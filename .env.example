# Optional: credentials for `pnpm demo:record` auto-login (also reads TEST_USERNAME / TEST_PASSWORD)
# DEMO_RECORD_EMAIL=
# DEMO_RECORD_PASSWORD=

# New-format keys (sb_publishable_* / sb_secret_*). Legacy anon / service_role
# JWTs also work but are deprecated.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<sb_publishable_...>
SUPABASE_SECRET_KEY=<sb_secret_...>

# Admin area dev/prod data switcher (maintainer-only; server-side only — these
# secret keys are never sent to the browser). The in-web admin area can manage
# either dataset; a dropdown selects which. 'dev' falls back to SUPABASE_URL
# above if left blank; 'prod' is only selectable once both PROD_ vars are set.
DEV_SUPABASE_URL=https://<dev-project-ref>.supabase.co
DEV_SUPABASE_SECRET_KEY=<sb_secret_...>
PROD_SUPABASE_URL=https://<prod-project-ref>.supabase.co
PROD_SUPABASE_SECRET_KEY=<sb_secret_...>

# Backend this app talks to. For local dev, point directly to the Go server port;
# the session WebSocket uses this URL too. Nitro server routes read this same
# value via runtimeConfig.public.serverUrl.
SERVER_URL=http://localhost:8081

# Frontend app URL (for verification links)
APP_URL=http://localhost:3000

# Auth cookie domain for cross-subdomain SSO (the product + admin.polymux.com).
# Set ONLY on the production env: COOKIE_DOMAIN=.polymux.com — leave it UNSET on
# localhost and *.vercel.app previews (host-scoped cookies). A mismatched domain
# silently breaks login.
# COOKIE_DOMAIN=

# Polymux browser extension ID (chrome.runtime.id). This is the Chrome Web
# Store-assigned ID of the published listing. Empty disables the website's
# auto-pair plugin. For a LOCAL unpacked build to share this ID (so dev and
# prod match), the same store "key" must be in manifest.json — otherwise the
# unpacked ID is path-derived and you must use that value here instead. See
# extension/README.md for the stable-ID setup.
EXTENSION_ID=abcoknklbjpjkchpejlfpkjlajmifgnk

# Chrome Web Store listing URL for the extension. Leave empty until the
# extension is published — the /install-apps page shows "Coming soon" while
# unset, then renders an "Install for Chrome" button. Use the PUBLIC listing
# URL (no /preview, no ?authuser/pli params). Once published:
# EXTENSION_STORE_URL=https://chromewebstore.google.com/detail/abcoknklbjpjkchpejlfpkjlajmifgnk
EXTENSION_STORE_URL=

# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# PostHog: feature flags, surveys, session replay, product analytics, and WS
# session linking for server-side LLM analytics. Use the same phc_ project key
# as polymux posthog.project_api_key. See polymux/docs/posthog-setup.md.
# POSTHOG_PUBLIC_KEY is the project API key (phc_...), safe in the browser.
# Leave empty to disable PostHog in dev (flags fail-open, UI gates stay on).
# POSTHOG_HOST defaults to https://us.i.posthog.com (ingest). For production
# first-party proxy: POSTHOG_HOST=https://h.polymux.com
POSTHOG_PUBLIC_KEY=
# POSTHOG_HOST=https://h.polymux.com

# Stripe: https://dashboard.stripe.com/apikeys
# NOTE: One Stripe account is used across BOTH dev (this file) and prod (Vercel):
# the "Polymux sandbox" account owned by carlvince@polymux.com
# (acct_1TZAK4Ru7Vrw0hsZ) — that's where the pricing.ts price IDs live. The
# secret + publishable keys here must match Vercel's STRIPE_SECRET_KEY /
# STRIPE_PUBLISHABLE_KEY (same account, same publishable key in both).
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Publishable key for in-app (embedded) Checkout — exposed to the browser, safe.
# MUST be from the same Stripe account as STRIPE_SECRET_KEY above. Same value is
# set on Vercel (Production + Preview) so prod and dev share one publishable key.
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Signing secret for the webhook endpoint. Local dev:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# (use the whsec_ it prints). Prod: a dashboard endpoint at
# <deploy-url>/api/stripe/webhook subscribed to checkout.session.completed,
# customer.subscription.updated, and customer.subscription.deleted.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Wallet feature kill switch (Nuxt mirror of the PostHog `wallet` flag). Set to
# true/1/on/yes to enable the wallet top-up endpoint + UI; unset (default) =
# disabled. Read by server/utils/billing/walletEnabled.ts.
# WALLET_ENABLED=

# Encryption key for OAuth tokens stored in workspace_integrations.
# Generate: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# Shared secret between Nuxt and the Go backend for /api/internal/* routes.
# Must match the polymux config's server.polymux_secret.
# Generate: openssl rand -hex 32
POLYMUX_SECRET=

# HMAC secret used to sign OAuth state tokens (5-min handshake).
# Generate: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Google OAuth client (Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI must include: {APP_URL}/api/integrations/google-drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backblaze B2: master application key for the bytes bucket. Backs workflow
# artifacts (all plans) and the Cloud persistent storage option (Pro/Max).
# Create at https://secure.backblaze.com/app_keys.htm scoped to one bucket.
# Install the CLI for dev/admin tasks: `brew install b2-tools`.
B2_MASTER_KEY_ID=
B2_MASTER_KEY=
B2_BUCKET_NAME=polymux-dev
