# Supabase: Dashboard → Project Settings → API Keys
# New-format keys (sb_publishable_* / sb_secret_*). Legacy anon / service_role
# JWTs also work but are deprecated.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<sb_publishable_...>
SUPABASE_SECRET_KEY=<sb_secret_...>

# Backend this app talks to
SERVER_URL=http://localhost:8080

# Frontend app URL (for verification links)
APP_URL=http://localhost:3000

# Polymux browser extension ID (chrome.runtime.id). Set to the value shown in
# chrome://extensions after loading the unpacked build. Empty disables the
# website's auto-pair plugin. See extension/README.md for the stable-ID setup.
EXTENSION_ID=ebdihhelngongclfbbodogjegafklklh

# Resend: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# PostHog: feature flags for the maintainer console's Governance tab.
# POSTHOG_PUBLIC_KEY is the project API key (phc_...), safe to ship to the
# browser. Leave empty to disable client-side flag evaluation (every gated
# feature renders as enabled — useful for dev environments).
# POSTHOG_HOST defaults to https://us.i.posthog.com if unset.
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Mirrors the PostHog `plan_limits` flag for Nuxt server routes (file upload
# caps, artifact caps, BYOK gate). The polymux Go server reads PostHog
# directly; Nuxt has no maintainer JWT to query the governance API, so it
# reads this env var instead. Set to `false` when toggling plan_limits off
# in PostHog so the Nuxt routes bypass their caps in lock-step. Default
# (unset) enforces — fail-safe.
PLAN_LIMITS_ENFORCE=true

# Stripe: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Encryption key for OAuth tokens stored in workspace_integrations.
# Generate: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# Shared secret between Nuxt and the Go backend for /api/internal/* routes.
# Must match the polymux config's server.polymux_secret.
# Generate: openssl rand -hex 32
POLYMUX_SECRET=

# HMAC secret used to sign OAuth state tokens (5-min handshake).
# Generate: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Google OAuth client (Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI must include: {APP_URL}/api/integrations/google-drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backblaze B2: master application key for the bytes bucket. Backs workflow
# artifacts (all plans) and the Cloud persistent storage option (Pro/Max).
# Create at https://secure.backblaze.com/app_keys.htm scoped to one bucket.
# Install the CLI for dev/admin tasks: `brew install b2-tools`.
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=polymux-prod
